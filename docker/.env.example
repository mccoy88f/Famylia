# Copia in docker/.env e personalizza
DB_PASSWORD=changeme_famylia_db
MINIO_USER=famylia
MINIO_PASSWORD=changeme_minio
JWT_SECRET=changeme_jwt_secret_min_32_chars_long

# Serverpod (opzionale, override passwords.yaml)
SERVERPOD_PASSWORD_jwtRefreshTokenHashPepper=dev_refresh_pepper_change_me
SERVERPOD_PASSWORD_jwtHmacSha512PrivateKey=dev_hmac_key_change_me_32chars_min
SERVERPOD_PASSWORD_emailSecretHashPepper=dev_email_pepper_change_me
